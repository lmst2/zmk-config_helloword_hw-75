DT_ALIAS_UART_COMM := uart-comm

config HW75_UART_COMM
	bool
	select SERIAL
	select HW75_PROTO_UART_COMM
	default $(dt_alias_enabled,$(DT_ALIAS_UART_COMM))

if HW75_UART_COMM

# Index of keymap layer used while keyboard holds FN (UART). Not hardcoded 1: layer 1 is "scroll".
config HW75_DYNAMIC_UART_FN_TARGET_LAYER
	int "Keymap layer index when keyboard FN is held"
	default 5
	range 0 31

config HW75_UART_COMM_THREAD_PRIORITY
	int
	default 10

config HW75_UART_COMM_THREAD_STACK_SIZE
	int
	default 1024

config HW75_UART_COMM_MAX_RX_MESSAGE_SIZE
	int
	default 64

module = HW75_UART_COMM
module-str = uart_comm
source "subsys/logging/Kconfig.template.log_config"

endif # HW75_UART_COMM
