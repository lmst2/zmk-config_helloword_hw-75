DT_ALIAS_UART_COMM := uart-comm

config HW75_UART_COMM
	bool
	select SERIAL
	select HW75_PROTO_UART_COMM
	default $(dt_alias_enabled,$(DT_ALIAS_UART_COMM))

if HW75_UART_COMM

# When y, keyboard UART tells dynamic MCU to force keymap layer 1 while FN is held.
# hw75_dynamic layer 1 is not "FN" (e.g. scroll mode) — causes OLED to jump. Default n.
config HW75_UART_FN_STATE_REPORT
	bool "UART: report keyboard FN layer to dynamic module"
	default n

config HW75_UART_COMM_MAX_TX_MESSAGE_SIZE
	int
	default 64

module = HW75_UART_COMM
module-str = uart_comm
source "subsys/logging/Kconfig.template.log_config"

endif # HW75_UART_COMM
